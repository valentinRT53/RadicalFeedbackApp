<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RadicalFeedbackApp.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RadicalFeedback">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#0A0A0B">

        <!-- Watermark RF en fond -->
        <TextBlock Text="RF"
                   FontSize="320"
                   FontFamily="Bebas Neue"
                   Foreground="#08080A"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Right"
                   Margin="0,0,-20,0"
                   IsHitTestVisible="False"/>

        <!-- Carte login centrée -->
        <Border Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#111114"
                BorderBrush="#2A2A32"
                BorderThickness="1"
                CornerRadius="2">
            <Grid>
                <!-- Barre rouge top -->
                <Border Height="2"
                        Background="#E8192C"
                        VerticalAlignment="Top"
                        CornerRadius="2,2,0,0"/>

                <StackPanel Padding="40,48,40,48" Spacing="0">

                    <!-- Logo -->
                    <TextBlock Text="RADICAL"
           FontSize="30"
           FontFamily="Bebas Neue"
           Foreground="White"
           CharacterSpacing="30"/>
                    <TextBlock Text="FEEDBACK"
           FontSize="30"
           FontFamily="Bebas Neue"
           Foreground="#E8192C"
           CharacterSpacing="30"/>

                    <TextBlock Text="ESPACE EXPERT"
                               FontSize="10"
                               CharacterSpacing="300"
                               Foreground="#6B6B7A"
                               Margin="0,0,0,40"/>

                    <!-- Champ login -->
                    <TextBlock Text="IDENTIFIANT"
                               FontSize="10"
                               CharacterSpacing="200"
                               Foreground="#6B6B7A"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="LoginBox"
                             PlaceholderText="Entrez votre identifiant"
                             Background="#18181D"
                             BorderBrush="#2A2A32"
                             BorderThickness="1"
                             Foreground="White"
                             Padding="16,12"
                             CornerRadius="2"
                             Margin="0,0,0,16"/>

                    <!-- Champ mot de passe -->
                    <TextBlock Text="MOT DE PASSE"
                               FontSize="10"
                               CharacterSpacing="200"
                               Foreground="#6B6B7A"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="MdpBox"
                                 PlaceholderText="••••••••"
                                 Background="#18181D"
                                 BorderBrush="#2A2A32"
                                 BorderThickness="1"
                                 Foreground="White"
                                 Padding="16,12"
                                 CornerRadius="2"
                                 Margin="0,0,0,8"/>

                    <!-- Message erreur -->
                    <TextBlock x:Name="ErreurText"
                               Text="Identifiants incorrects ou accès refusé."
                               Foreground="#E8192C"
                               FontSize="12"
                               Visibility="Collapsed"
                               Margin="0,0,0,16"/>

                    <!-- Bouton connexion -->
                    <Button x:Name="ConnexionBtn"
                            Content="SE CONNECTER"
                            HorizontalAlignment="Stretch"
                            Background="#E8192C"
                            Foreground="White"
                            FontFamily="Bebas Neue"
                            FontSize="16"
                            Padding="0,14"
                            CornerRadius="2"
                            Margin="0,16,0,0"
                            Click="ConnexionBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>