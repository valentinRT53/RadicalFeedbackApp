<Page
    x:Class="RadicalFeedbackApp.Views.AbonnementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RadicalFeedbackApp.ViewModels">
    <Page.DataContext>
        <vm:AbonnementViewModel/>
    </Page.DataContext>

    <Grid Background="#0A0A0B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="PanelColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LISTE ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="32,28,32,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ABONNEMENTS"
                                   FontFamily="Bebas Neue"
                                   FontSize="28"
                                   CharacterSpacing="20"
                                   Foreground="White"/>
                        <TextBlock Text="Plans et souscriptions"
                                   FontSize="12"
                                   Foreground="#6B6B7A"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button x:Name="BtnAjouter"
                            Grid.Column="1"
                            Content="+ AJOUTER"
                            Background="#E8192C"
                            Foreground="White"
                            FontFamily="Bebas Neue"
                            FontSize="14"
                            Padding="20,10"
                            CornerRadius="2"
                            VerticalAlignment="Center"
                            Click="BtnAjouter_Click"/>
                </Grid>
            </Border>

            <!-- Cartes -->
            <ScrollViewer Grid.Row="1" Padding="32,24">
                <ItemsControl ItemsSource="{Binding Abonnements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="240"
                                    Margin="0,0,16,16"
                                    Background="#111114"
                                    BorderBrush="#2A2A32"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid>
                                    <Border Height="2" Background="#E8192C"
                                            VerticalAlignment="Top" CornerRadius="2,2,0,0"/>
                                    <StackPanel Padding="20,24,20,20" Spacing="0">

                                        <!-- Prix -->
                                        <TextBlock Text="PRIX MENSUEL" FontSize="9"
                                                   CharacterSpacing="200" Foreground="#6B6B7A"
                                                   Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,16">
                                            <TextBlock Text="{Binding Prix}"
                                                       FontFamily="Bebas Neue"
                                                       FontSize="36"
                                                       Foreground="#E8192C"/>
                                            <TextBlock Text="€"
                                                       FontFamily="Bebas Neue"
                                                       FontSize="20"
                                                       Foreground="#E8192C"
                                                       VerticalAlignment="Bottom"
                                                       Margin="0,0,0,6"/>
                                        </StackPanel>

                                        <Border Height="1" Background="#2A2A32" Margin="0,0,0,16"/>

                                        <!-- Date + nb users -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="SOUSCRIPTION" FontSize="9"
                                                           CharacterSpacing="200" Foreground="#6B6B7A"/>
                                                <TextBlock Text="{Binding DateSouscription}"
                                                           FontSize="11" Foreground="#A0A0B0"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="ABONNÉS" FontSize="9"
                                                           CharacterSpacing="200" Foreground="#6B6B7A"/>
                                                <TextBlock Text="{Binding NbUtilisateurs}"
                                                           FontFamily="Bebas Neue" FontSize="20"
                                                           Foreground="White" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Boutons -->
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="VOIR ABONNÉS"
                                                    Tag="{Binding}"
                                                    Background="#18181D"
                                                    Foreground="#A0A0B0"
                                                    FontFamily="Bebas Neue"
                                                    FontSize="12"
                                                    Padding="12,6"
                                                    CornerRadius="2"
                                                    Click="BtnVoirAbonnes_Click"/>
                                            <Button Content="✕"
                                                    Tag="{Binding}"
                                                    Background="#1E0508"
                                                    Foreground="#E8192C"
                                                    FontSize="12"
                                                    Padding="12,6"
                                                    CornerRadius="2"
                                                    Click="BtnSupprimer_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ═══ SIDE PANEL ═══ -->
        <Border x:Name="SidePanel"
                Grid.Column="1"
                Background="#111114"
                BorderBrush="#2A2A32"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header panel -->
                <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="24,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PanelTitre"
                                   FontFamily="Bebas Neue"
                                   FontSize="20"
                                   CharacterSpacing="20"
                                   Foreground="White"/>
                        <Button Grid.Column="1" Content="✕"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#6B6B7A" FontSize="14"
                                Click="BtnFermer_Click"/>
                    </Grid>
                </Border>

                <!-- Contenu panel -->
                <ScrollViewer Grid.Row="1" Padding="24,20">
                    <StackPanel Spacing="16">

                        <!-- Mode ajout -->
                        <StackPanel x:Name="FormulairePanel" Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="PRIX (€)" FontSize="9"
                                           CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <TextBox x:Name="ChampPrix"
                                         Background="#18181D" BorderBrush="#2A2A32"
                                         Foreground="White" Padding="12,10" CornerRadius="2"
                                         PlaceholderText="Ex: 19.99"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="DATE DE SOUSCRIPTION" FontSize="9"
                                           CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <CalendarDatePicker x:Name="ChampDate"
                                                    Background="#18181D"
                                                    BorderBrush="#2A2A32"
                                                    Foreground="White"
                                                    HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <TextBlock x:Name="PanelErreur"
                                       Foreground="#E8192C" FontSize="12"
                                       Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Mode liste abonnés -->
                        <StackPanel x:Name="AbonnesPanel" Visibility="Collapsed" Spacing="12">
                            <TextBlock x:Name="AbonnesCount"
                                       FontSize="11" Foreground="#6B6B7A"/>
                            <ItemsControl x:Name="AbonnesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#18181D" CornerRadius="2"
                                                Padding="12,10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontSize="13" Foreground="White">
                                                        <Run Text="{Binding Prenom}"/>
                                                        <Run Text="{Binding Nom}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Email}"
                                                               FontSize="11" Foreground="#6B6B7A"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="2"
                                                        Padding="6,3" Background="#1A1A24"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Role}"
                                                               FontSize="10" Foreground="#6B6B7A"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Bouton valider (visible uniquement mode ajout) -->
                <Border x:Name="BtnValiderBorder"
                        Grid.Row="2" BorderBrush="#2A2A32"
                        BorderThickness="0,1,0,0" Padding="24,16">
                    <Button x:Name="BtnValider"
                            HorizontalAlignment="Stretch"
                            Background="#E8192C" Foreground="White"
                            FontFamily="Bebas Neue" FontSize="16"
                            Padding="0,12" CornerRadius="2"
                            Content="CRÉER L'ABONNEMENT"
                            Click="BtnValider_Click"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>