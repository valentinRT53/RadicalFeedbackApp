<Page
    x:Class="RadicalFeedbackApp.Views.SignalementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RadicalFeedbackApp.ViewModels">
    <Page.DataContext>
        <vm:SignalementViewModel/>
    </Page.DataContext>

    <Grid Background="#0A0A0B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="DetailColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LISTE ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header + Filtres -->
            <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="32,28,32,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titre -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="SIGNALEMENTS"
                                   FontFamily="Bebas Neue"
                                   FontSize="28"
                                   CharacterSpacing="20"
                                   Foreground="White"/>
                        <TextBlock Text="Problèmes signalés par les utilisateurs"
                                   FontSize="12"
                                   Foreground="#6B6B7A"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Filtres -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Filtre expert dynamique -->
                        <ComboBox Grid.Column="0"
                                  Margin="0,0,12,0"
                                  Background="#18181D"
                                  BorderBrush="#2A2A32"
                                  Foreground="White"
                                  CornerRadius="2"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Experts}"
                                  SelectedIndex="{Binding FiltreExpertIndex, Mode=TwoWay}"/>

                        <!-- Filtre catégorie -->
                        <ComboBox Grid.Column="1"
                                  Width="220"
                                  Background="#18181D"
                                  BorderBrush="#2A2A32"
                                  Foreground="White"
                                  CornerRadius="2"
                                  SelectedIndex="{Binding FiltreCategorie, Mode=TwoWay}">
                            <ComboBoxItem Content="Toutes les catégories"/>
                            <ComboBoxItem Content="Comportement inapproprié"/>
                            <ComboBoxItem Content="Contenu incorrect"/>
                        </ComboBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- Cartes -->
            <ScrollViewer Grid.Row="1" Padding="32,24">
                <ItemsControl ItemsSource="{Binding Signalements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300"
                                    Margin="0,0,16,16"
                                    Background="#111114"
                                    BorderBrush="#2A2A32"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid>
                                    <Border Height="2" Background="#E8192C"
                                            VerticalAlignment="Top" CornerRadius="2,2,0,0"/>
                                    <StackPanel Padding="20,24,20,20" Spacing="0">

                                        <!-- Badge catégorie -->
                                        <Border CornerRadius="2" Padding="8,4"
                                                HorizontalAlignment="Left" Margin="0,0,0,12">
                                            <Border.Background>
                                                <SolidColorBrush Color="#1E0508"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Categorie}"
                                                       FontSize="10"
                                                       CharacterSpacing="100"
                                                       Foreground="#E8192C"/>
                                        </Border>

                                        <!-- Cible -->
                                        <TextBlock Text="{Binding Cible}"
                                                   FontFamily="Bebas Neue"
                                                   FontSize="16"
                                                   CharacterSpacing="10"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <!-- Commentaire -->
                                        <TextBlock Text="{Binding Commentaire}"
                                                   FontSize="12"
                                                   Foreground="#A0A0B0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <Border Height="1" Background="#2A2A32" Margin="0,0,0,16"/>

                                        <!-- Signalé par + date -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="SIGNALÉ PAR" FontSize="9"
                                                           CharacterSpacing="200" Foreground="#6B6B7A"/>
                                                <TextBlock FontSize="12" Foreground="#A0A0B0" Margin="0,4,0,0">
                                                    <Run Text="{Binding PrenomUtilisateur}"/>
                                                    <Run Text="{Binding NomUtilisateur}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="DATE" FontSize="9"
                                                           CharacterSpacing="200" Foreground="#6B6B7A"/>
                                                <TextBlock Text="{Binding DateSignalement}"
                                                           FontSize="11" Foreground="#A0A0B0"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Spacing="8">
                                            <Button Content="VOIR LE DÉTAIL"
            Tag="{Binding}"
            HorizontalAlignment="Stretch"
            Background="#18181D"
            Foreground="#A0A0B0"
            FontFamily="Bebas Neue"
            FontSize="12"
            Padding="0,8"
            CornerRadius="2"
            Click="BtnDetail_Click"/>
                                            <Button Content="SUPPRIMER"
            Tag="{Binding}"
            HorizontalAlignment="Stretch"
            Background="#1E0508"
            Foreground="#E8192C"
            FontFamily="Bebas Neue"
            FontSize="12"
            Padding="0,8"
            CornerRadius="2"
            Click="BtnSupprimer_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ═══ PANEL DÉTAIL ═══ -->
        <Border x:Name="DetailPanel"
                Grid.Column="1"
                Background="#111114"
                BorderBrush="#2A2A32"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header panel -->
                <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="24,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DetailTitre"
                                   FontFamily="Bebas Neue"
                                   FontSize="20"
                                   CharacterSpacing="20"
                                   Foreground="White"/>
                        <Button Grid.Column="1"
                                Content="✕"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#6B6B7A"
                                FontSize="14"
                                Click="BtnFermerDetail_Click"/>
                    </Grid>
                </Border>

                <!-- Contenu détail -->
                <ScrollViewer Grid.Row="1" Padding="24,20">
                    <StackPanel Spacing="16">

                        <StackPanel Spacing="6">
                            <TextBlock Text="CATÉGORIE" FontSize="9"
                                       CharacterSpacing="200" Foreground="#6B6B7A"/>
                            <TextBlock x:Name="DetailCategorie"
                                       FontSize="14" Foreground="#E8192C"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="SIGNALÉ PAR" FontSize="9"
                                       CharacterSpacing="200" Foreground="#6B6B7A"/>
                            <TextBlock x:Name="DetailAuteur"
                                       FontSize="14" Foreground="White"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="CIBLE" FontSize="9"
                                       CharacterSpacing="200" Foreground="#6B6B7A"/>
                            <TextBlock x:Name="DetailCible"
                                       FontSize="14" Foreground="White"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="COMMENTAIRE" FontSize="9"
                                       CharacterSpacing="200" Foreground="#6B6B7A"/>
                            <TextBlock x:Name="DetailCommentaire"
                                       FontSize="13" Foreground="#A0A0B0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Height="1" Background="#2A2A32"/>

                        <!-- Messages conversation -->
                        <StackPanel x:Name="ConversationPanel"
                                    Visibility="Collapsed" Spacing="8">
                            <TextBlock Text="CONVERSATION" FontSize="9"
                                       CharacterSpacing="200" Foreground="#6B6B7A"/>
                            <ItemsControl x:Name="MessagesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#18181D"
                                                CornerRadius="2"
                                                Padding="12,10"
                                                Margin="0,0,0,8">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="#A0A0B0"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>