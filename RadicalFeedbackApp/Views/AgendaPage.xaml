<Page
    x:Class="RadicalFeedbackApp.Views.AgendaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RadicalFeedbackApp.ViewModels">
    <Page.DataContext>
        <vm:AgendaViewModel/>
    </Page.DataContext>

    <Grid Background="#0A0A0B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="32,28,32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="AGENDA"
                               FontFamily="Bebas Neue"
                               FontSize="28"
                               CharacterSpacing="20"
                               Foreground="White"/>
                    <TextBlock Text="Disponibilités de la semaine"
                               FontSize="12"
                               Foreground="#6B6B7A"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Menu déroulant admin -->
                <ComboBox x:Name="UtilisateurCombo"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          Width="200"
                          Background="#111114"
                          Foreground="White"
                          BorderBrush="#2A2A32"
                          Visibility="Collapsed"
                          SelectionChanged="UtilisateurCombo_SelectionChanged"/>
            </Grid>
        </Border>

        <!-- Grille agenda -->
        <ScrollViewer Grid.Row="1" Padding="32,24">
            <Grid x:Name="AgendaGrid"/>
        </ScrollViewer>
    </Grid>
</Page>