
<Page
    x:Class="RadicalFeedbackApp.Views.CategoriePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RadicalFeedbackApp.ViewModels"
    >
    <Page.DataContext>
        <vm:CategorieViewModel/>
    </Page.DataContext>

    <Grid Background="#0A0A0B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="32,28,32,20">
            <StackPanel>
                <TextBlock Text="CATÉGORIES"
                           FontFamily="Bebas Neue"
                           FontSize="28"
                           CharacterSpacing="20"
                           Foreground="White"/>
                <TextBlock Text="Classification des contenus"
                           FontSize="12"
                           Foreground="#6B6B7A"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Grille de cartes -->
        <ScrollViewer Grid.Row="1" Padding="32,24">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200"
                                Margin="0,0,16,16"
                                Background="#111114"
                                BorderBrush="#2A2A32"
                                BorderThickness="1"
                                CornerRadius="2">
                            <Grid>
                                <Border Height="2" Background="#E8192C"
                                        VerticalAlignment="Top" CornerRadius="2,2,0,0"/>

                                <StackPanel Padding="20,24,20,20" Spacing="0">

                                    <TextBlock Text="ID" FontSize="9" CharacterSpacing="200"
                                               Foreground="#6B6B7A" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Id}"
                                               FontFamily="Bebas Neue"
                                               FontSize="28"
                                               Foreground="#E8192C"
                                               Margin="0,0,0,16"/>

                                    <Border Height="1" Background="#2A2A32" Margin="0,0,0,16"/>

                                    <TextBlock Text="NOM" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                    <TextBlock Text="{Binding Nom}"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               Foreground="White"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>