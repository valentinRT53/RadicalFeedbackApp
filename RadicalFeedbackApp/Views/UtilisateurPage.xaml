<Page
    x:Class="RadicalFeedbackApp.Views.UtilisateurPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RadicalFeedbackApp.ViewModels">
    <Page.DataContext>
        <vm:UtilisateurViewModel/>
    </Page.DataContext>

    <Grid Background="#0A0A0B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="PanelColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LISTE ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <!-- Remplace uniquement le Header (Border Grid.Row="0") -->
            <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="32,28,32,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titre + bouton ajouter -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="UTILISATEURS"
                           FontFamily="Bebas Neue"
                           FontSize="28"
                           CharacterSpacing="20"
                           Foreground="White"/>
                            <TextBlock Text="Gestion des comptes"
                           FontSize="12"
                           Foreground="#6B6B7A"
                           Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button x:Name="BtnAjouter"
                    Grid.Column="1"
                    Content="+ AJOUTER"
                    Background="#E8192C"
                    Foreground="White"
                    FontFamily="Bebas Neue"
                    FontSize="14"
                    CharacterSpacing="100"
                    Padding="20,10"
                    CornerRadius="2"
                    VerticalAlignment="Center"
                    Click="BtnAjouter_Click"/>
                    </Grid>

                    <!-- Barre de recherche + filtres -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Recherche -->
                        <TextBox Grid.Column="0"
                     PlaceholderText="Rechercher par nom, prénom, email, ville..."
                     Background="#18181D"
                     BorderBrush="#2A2A32"
                     Foreground="White"
                     Padding="12,10"
                     CornerRadius="2"
                     Margin="0,0,12,0"
                     Text="{Binding Recherche, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Filtre rôle -->
                        <ComboBox Grid.Column="1"
                      Width="150"
                      Background="#18181D"
                      BorderBrush="#2A2A32"
                      Foreground="White"
                      CornerRadius="2"
                      Margin="0,0,12,0"
                      SelectedIndex="{Binding RoleFiltre, Mode=TwoWay}">
                            <ComboBoxItem Content="Tous les rôles"/>
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="Expert"/>
                            <ComboBoxItem Content="Utilisateur"/>
                        </ComboBox>

                        <!-- Tri -->
                        <ComboBox Grid.Column="2"
                      Width="160"
                      Background="#18181D"
                      BorderBrush="#2A2A32"
                      Foreground="White"
                      CornerRadius="2"
                      SelectedIndex="{Binding TriSelectionne, Mode=TwoWay}">
                            <ComboBoxItem Content="Tri : Par défaut"/>
                            <ComboBoxItem Content="Tri : Nom"/>
                            <ComboBoxItem Content="Tri : Prénom"/>
                            <ComboBoxItem Content="Tri : Rôle"/>
                            <ComboBoxItem Content="Tri : Ville"/>
                        </ComboBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- Cartes -->
            <ScrollViewer Grid.Row="1" Padding="32,24">
                <ItemsControl ItemsSource="{Binding Utilisateurs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="260"
                                    Margin="0,0,16,16"
                                    Background="#111114"
                                    BorderBrush="#2A2A32"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid>
                                    <Border Height="2" Background="#E8192C"
                                            VerticalAlignment="Top" CornerRadius="2,2,0,0"/>
                                    <StackPanel Padding="20,24,20,20" Spacing="0">

                                        <!-- Avatar + Nom -->
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                                            <Border Background="#7A0D17" CornerRadius="2" Width="36" Height="36">
                                                <TextBlock FontFamily="Bebas Neue" FontSize="14"
                                                           Foreground="#E8192C"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding Prenom}"/>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock FontSize="14" FontWeight="Medium" Foreground="White">
                                                    <Run Text="{Binding Prenom}"/>
                                                    <Run Text="{Binding Nom}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Email}" FontSize="11" Foreground="#6B6B7A"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="#2A2A32" Margin="0,0,0,16"/>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="VILLE" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                                <TextBlock Text="{Binding Ville}" FontSize="12" Foreground="#A0A0B0" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="STATUT" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                                <TextBlock Text="{Binding Statut}" FontSize="12" Foreground="#A0A0B0" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Après le badge statut existant -->
                                        <Border CornerRadius="2" Padding="8,4" HorizontalAlignment="Left" Margin="0,6,0,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#1A1A24"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Role}"
               FontSize="10"
               CharacterSpacing="100"
               Foreground="#6B6B7A"/>
                                        </Border>


                                        <!-- Boutons actions -->
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="MODIFIER"
                                                    Tag="{Binding}"
                                                    Background="#18181D"
                                                    Foreground="#A0A0B0"
                                                    FontFamily="Bebas Neue"
                                                    FontSize="12"
                                                    Padding="12,6"
                                                    CornerRadius="2"
                                                    Click="BtnModifier_Click"/>
                                            <Button Content="MDP"
                                                    Tag="{Binding}"
                                                    Background="#18181D"
                                                    Foreground="#A0A0B0"
                                                    FontFamily="Bebas Neue"
                                                    FontSize="12"
                                                    Padding="12,6"
                                                    CornerRadius="2"
                                                    Click="BtnMdp_Click"/>
                                            <Button Content="✕"
                                                    Tag="{Binding}"
                                                    Background="#1E0508"
                                                    Foreground="#E8192C"
                                                    FontSize="12"
                                                    Padding="12,6"
                                                    CornerRadius="2"
                                                    Click="BtnSupprimer_Click"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ═══ SIDE PANEL ═══ -->
        <Border x:Name="SidePanel"
                Grid.Column="1"
                Background="#111114"
                BorderBrush="#2A2A32"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header panel -->
                <Border Grid.Row="0" BorderBrush="#2A2A32" BorderThickness="0,0,0,1" Padding="24,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PanelTitre"
                                   FontFamily="Bebas Neue"
                                   FontSize="20"
                                   CharacterSpacing="20"
                                   Foreground="White"/>
                        <Button Grid.Column="1"
                                Content="✕"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#6B6B7A"
                                FontSize="14"
                                Click="BtnFermerPanel_Click"/>
                    </Grid>
                </Border>

                <!-- Formulaire -->
                <ScrollViewer Grid.Row="1" Padding="24,20">
                    <StackPanel Spacing="16">

                        <StackPanel x:Name="ChampLoginPanel" Spacing="8">
                            <TextBlock Text="LOGIN" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                            <TextBox x:Name="ChampLogin" Background="#18181D" BorderBrush="#2A2A32"
                                     Foreground="White" Padding="12,10" CornerRadius="2"/>
                        </StackPanel>

                        <StackPanel x:Name="ChampMdpPanel" Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="NOUVEAU MOT DE PASSE"
                   FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <PasswordBox x:Name="ChampMdp"
                     Background="#18181D" BorderBrush="#2A2A32"
                     Foreground="White" Padding="12,10" CornerRadius="2"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="CONFIRMER LE MOT DE PASSE"
                   FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <PasswordBox x:Name="ChampMdpConfirm"
                     Background="#18181D" BorderBrush="#2A2A32"
                     Foreground="White" Padding="12,10" CornerRadius="2"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ChampInfosPanel" Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="NOM" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <TextBox x:Name="ChampNom" Background="#18181D" BorderBrush="#2A2A32"
                 Foreground="White" Padding="12,10" CornerRadius="2"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="PRÉNOM" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <TextBox x:Name="ChampPrenom" Background="#18181D" BorderBrush="#2A2A32"
                 Foreground="White" Padding="12,10" CornerRadius="2"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="EMAIL" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <TextBox x:Name="ChampEmail" Background="#18181D" BorderBrush="#2A2A32"
                 Foreground="White" Padding="12,10" CornerRadius="2"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="VILLE" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <TextBox x:Name="ChampVille" Background="#18181D" BorderBrush="#2A2A32"
                 Foreground="White" Padding="12,10" CornerRadius="2"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="STATUT" FontSize="9" CharacterSpacing="200" Foreground="#6B6B7A"/>
                                <ComboBox x:Name="ChampStatut"
                  Background="#18181D" BorderBrush="#2A2A32"
                  Foreground="White" CornerRadius="2"
                  HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Actif"/>
                                    <ComboBoxItem Content="Inactif"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- IDs en lecture seule -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="ID UTILISATEUR" FontSize="9"
                       CharacterSpacing="200" Foreground="#6B6B7A"/>
                                    <TextBlock x:Name="LabelIdUtilisateur"
                       FontFamily="Bebas Neue" FontSize="20"
                       Foreground="#E8192C"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="ID ABONNEMENT" FontSize="9"
                       CharacterSpacing="200" Foreground="#6B6B7A"/>
                                    <TextBlock x:Name="LabelIdAbonnement"
                       FontFamily="Bebas Neue" FontSize="20"
                       Foreground="#E8192C"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Spécialisations (visible uniquement en mode modifier expert) -->
                        <StackPanel x:Name="ChampSpecialisationsPanel" Visibility="Collapsed" Spacing="8">
                            <TextBlock Text="SPÉCIALISATIONS" FontSize="9"
               CharacterSpacing="200" Foreground="#6B6B7A"/>
                            <ItemsControl x:Name="SpecialisationsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Nom}"
                          Tag="{Binding}"
                          Foreground="White"
                          Margin="0,4,0,0"
                          Checked="SpecCheckBox_Changed"
                          Unchecked="SpecCheckBox_Changed"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock x:Name="PanelErreur"
                                   Foreground="#E8192C"
                                   FontSize="12"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bouton valider -->
                <Border Grid.Row="2" BorderBrush="#2A2A32" BorderThickness="0,1,0,0" Padding="24,16">
                    <Button x:Name="BtnValider"
                            HorizontalAlignment="Stretch"
                            Background="#E8192C"
                            Foreground="White"
                            FontFamily="Bebas Neue"
                            FontSize="16"
                            CharacterSpacing="100"
                            Padding="0,12"
                            CornerRadius="2"
                            Click="BtnValider_Click"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>