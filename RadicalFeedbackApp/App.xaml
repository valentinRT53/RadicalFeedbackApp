<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="RadicalFeedbackApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Couleurs globales -->
            <SolidColorBrush x:Key="AccentRedBrush" Color="#E8192C"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#111114"/>
            <SolidColorBrush x:Key="Surface2Brush" Color="#18181D"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#2A2A32"/>
            <SolidColorBrush x:Key="TextDimBrush" Color="#6B6B7A"/>
            <SolidColorBrush x:Key="TextMidBrush" Color="#A0A0B0"/>

            
            
        </ResourceDictionary>
    </Application.Resources>
</Application>