<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RadicalFeedbackApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="RadicalFeedback">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#0A0A0B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0"
                Background="#111114"
                BorderBrush="#2A2A32"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header logo -->
                <Border Grid.Row="0"
                        BorderBrush="#2A2A32"
                        BorderThickness="0,0,0,1"
                        Padding="20,24,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="RADICAL"
           FontSize="18"
           FontFamily="Bebas Neue"
           Foreground="White"
           CharacterSpacing="20"/>
                            <TextBlock Text="FEEDBACK"
           FontSize="18"
           FontFamily="Bebas Neue"
           Foreground="#E8192C"
           CharacterSpacing="20"/>
                        </StackPanel>
                        <TextBlock x:Name="RoleLabel"
                                   FontSize="9"
                                   CharacterSpacing="200"
                                   Foreground="#6B6B7A"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <StackPanel Grid.Row="1" Padding="12,20,12,0" Spacing="2">

                    <TextBlock Text="NAVIGATION"
                               FontSize="9"
                               CharacterSpacing="300"
                               Foreground="#6B6B7A"
                               Margin="8,0,0,8"/>

                    <Button x:Name="NavUtilisateurs"
                            Tag="utilisateurs"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#A0A0B0"
                            Padding="12,10"
                            CornerRadius="2"
                            Click="NavItem_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE716;" FontSize="14"/>
                            <TextBlock Text="Utilisateurs" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavAgenda"
 Tag="agenda"
 HorizontalAlignment="Stretch"
 HorizontalContentAlignment="Left"
 Background="Transparent"
 BorderThickness="0"
 Foreground="#A0A0B0"
 Padding="12,10"
 CornerRadius="2"
 Click="NavItem_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE787;" FontSize="14"/>
                            <TextBlock Text="Agenda" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavSpecialisations"
        Tag="specialisations"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Left"
        Background="Transparent"
        BorderThickness="0"
        Foreground="#A0A0B0"
        Padding="12,10"
        CornerRadius="2"
        Click="NavItem_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8D7;" FontSize="14"/>
                            <TextBlock Text="Spécialisations" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavAvis"
                            Tag="avis"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#A0A0B0"
                            Padding="12,10"
                            CornerRadius="2"
                            Click="NavItem_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8F2;" FontSize="14"/>
                            <TextBlock Text="Avis" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavSignalements"
                            Tag="signalements"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#A0A0B0"
                            Padding="12,10"
                            CornerRadius="2"
                            Click="NavItem_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7BA;" FontSize="14"/>
                            <TextBlock Text="Signalements" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavAbonnements"
                            Tag="abonnements"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#A0A0B0"
                            Padding="12,10"
                            CornerRadius="2"
                            Click="NavItem_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7BF;" FontSize="14"/>
                            <TextBlock Text="Abonnements" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    

                </StackPanel>

                <!-- Footer utilisateur -->
                <Border Grid.Row="2"
        BorderBrush="#2A2A32"
        BorderThickness="0,1,0,0"
        Padding="12,16">
                    <StackPanel Spacing="8">
                        <Border Background="#18181D" CornerRadius="2" Padding="12,10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Background="#7A0D17" CornerRadius="2" Width="28" Height="28">
                                    <TextBlock x:Name="AvatarText"
                               FontFamily="Bebas Neue" FontSize="13"
                               Foreground="#E8192C"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="UserNameText" FontSize="12"
                               FontWeight="Medium" Foreground="White"/>
                                    <TextBlock x:Name="UserRoleText" FontSize="10"
                               CharacterSpacing="100" Foreground="#6B6B7A"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Bouton quitter -->
                        <Button Content="QUITTER"
                HorizontalAlignment="Stretch"
                Background="#1E0508"
                Foreground="#E8192C"
                FontFamily="Bebas Neue"
                FontSize="13"
                CharacterSpacing="100"
                Padding="0,10"
                CornerRadius="2"
                Click="BtnQuitter_Click"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ═══ CONTENU ═══ -->
        <Frame x:Name="ContentFrame" Grid.Column="1"/>


       

    </Grid>
</Window>